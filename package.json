{
  "name": "postiz-app",
  "version": "1.0.0",
  "private": true,
  "description": "Postiz - Social Media Scheduling & Management Platform",
  "scripts": {
    "dev": "nx run-many --target=serve --all --parallel",
    "build": "nx run-many --target=build --all",
    "test": "nx run-many --target=test --all",
    "lint": "nx run-many --target=lint --all",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "db:migrate": "nx run backend:db:migrate",
    "db:generate": "nx run backend:db:generate",
    "db:reset": "nx run backend:db:reset",
    "dev:frontend": "nx run frontend:serve",
    "dev:backend": "nx run backend:serve",
    "dev:debug": "nx run backend:serve --inspect",
    "dev:verbose": "nx run-many --target=serve --all --parallel --verbose",
    "clean": "nx reset && rm -rf node_modules dist",
    "clean:dist": "rm -rf dist"
  },
  "workspaces": [
    "apps/*",
    "libraries/*"
  ],
  "dependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/jwt": "^10.0.0",
    "@nestjs/passport": "^10.0.0",
    "@prisma/client": "^5.0.0",
    "next": "^14.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "axios": "^1.6.0",
    "bull": "^4.12.0",
    "ioredis": "^5.3.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "dayjs": "^1.11.10",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@nx/eslint": "^17.0.0",
    "@nx/eslint-plugin": "^17.0.0",
    "@nx/jest": "^17.0.0",
    "@nx/next": "^17.0.0",
    "@nx/nest": "^17.0.0",
    "@nx/node": "^17.0.0",
    "@nx/workspace": "^17.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.0.0",
    "@types/passport-jwt": "^4.0.0",
    "@types/passport-local": "^1.0.38",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "eslint-config-next": "^14.0.0",
    "jest": "^29.0.0",
    "nx": "^17.0.0",
    "prettier": "^3.0.0",
    "prisma": "^5.0.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
